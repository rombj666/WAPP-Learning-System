@model ILOWLearningSystem.Web.Models.EditProfileViewModel

@{
    ViewData["Title"] = "Edit Profile";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-7">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-body p-4">
                    <h2 class="fw-bold mb-4">Edit Profile</h2>

                    <form asp-action="EditProfile" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="FullName" class="form-label fw-semibold"></label>
                            <input asp-for="FullName" class="form-control rounded-3" />
                            <span asp-validation-for="FullName" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Email" class="form-label fw-semibold"></label>
                            <input asp-for="Email" class="form-control rounded-3" readonly />
                            <small class="text-muted">Email cannot be changed.</small>
                        </div>

                        <div class="mb-4">
                            <label asp-for="ProfileThemeColor" class="form-label fw-semibold">Profile Banner Color</label>
                            <div class="d-flex align-items-center gap-3">
                                <input asp-for="ProfileThemeColor" type="color" class="form-control form-control-color" style="width: 80px; height: 50px;" />
                                <span class="text-muted">Choose your preferred banner color</span>
                            </div>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-dark rounded-3">Save Changes</button>
                            <a asp-action="Profile" class="btn btn-outline-secondary rounded-3">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}