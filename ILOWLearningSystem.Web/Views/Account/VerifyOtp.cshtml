@model ILOWLearningSystem.Web.Models.VerifyOtpViewModel
@{
    ViewData["Title"] = "Verify OTP";
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
}

<div class="row justify-content-center">
    <div class="col-12 col-md-8 col-lg-5">
        <div class="p-4 bg-white ilow-card">
            <h1 class="h4 ilow-page-title mb-3">Verify OTP</h1>

            @if (TempData["OtpMessage"] != null)
            {
                <div class="alert alert-info">
                    @TempData["OtpMessage"]
                </div>
            }

            <form asp-action="VerifyOtp" method="post">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <input asp-for="Email" type="hidden" />

                <div class="mb-3">
                    <label asp-for="Otp" class="form-label"></label>
                    <input asp-for="Otp" class="form-control" />
                    <span asp-validation-for="Otp" class="text-danger"></span>
                </div>

                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-primary">Verify OTP</button>
                    <a class="btn btn-outline-secondary" asp-controller="Account" asp-action="Login">Back to Login</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}