@model ILOWLearningSystem.Web.Models.User

@{
    ViewData["Title"] = "My Profile";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="card shadow-sm">
            <div class="card-body">
                <h2 class="mb-4">My Profile</h2>

                <div class="mb-3">
                    <label class="form-label fw-bold">Full Name</label>
                    <div class="form-control">@Model.FullName</div>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Email</label>
                    <div class="form-control">@Model.Email</div>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Role</label>
                    <div class="form-control">@Model.Role</div>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Created At</label>
                    <div class="form-control">@Model.CreatedAt.ToString("dd/MM/yyyy hh:mm tt")</div>
                </div>
            </div>
        </div>
    </div>
</div>