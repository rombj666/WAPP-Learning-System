@model List<ILOWLearningSystem.Web.Models.Lesson>
@{
    ViewData["Title"] = "Manage Lessons";
    var courses = ViewBag.Courses as List<ILOWLearningSystem.Web.Models.Course>;
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
    <h1 class="h4 ilow-page-title m-0">Manage Lessons</h1>
    <div>
        <a class="btn btn-sm btn-outline-secondary" asp-action="Dashboard">
            <i class="bi bi-arrow-left"></i> Back to Dashboard
        </a>
        <button class="btn btn-sm btn-primary ms-2" data-bs-toggle="modal" data-bs-target="#addLessonModal">
            <i class="bi bi-plus-lg"></i> Add Lesson
        </button>
    </div>
</div>

@if (TempData["Message"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Message"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="ilow-card bg-white p-3">
    <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
            <tr>
                <th>#</th>
                <th>Title</th>
                <th>Course</th>
                <th>Created At</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Count == 0)
            {
                <tr>
                    <td colspan="5" class="text-center text-muted py-4">No lessons found.</td>
                </tr>
            }
            else
            {
                int index = 1;
                foreach (var lesson in Model)
                {
                    <tr>
                        <td>@index</td>
                        <td class="fw-semibold">@lesson.Title</td>
                        <td>
                            <span class="badge bg-info text-dark">@(lesson.Course?.Title ?? "—")</span>
                        </td>
                        <td>@lesson.CreatedAt.ToString("dd MMM yyyy")</td>
                        <td class="text-end">
                            <button class="btn btn-sm btn-outline-warning me-1"
                                    data-bs-toggle="modal" data-bs-target="#editLessonModal"
                                    data-id="@lesson.LessonId"
                                    data-title="@lesson.Title"
                                    data-content="@lesson.Content"
                                    data-courseid="@lesson.CourseId"
                                    data-slidepath="@lesson.SlidePath"
                                    data-videopath="@lesson.VideoPath">
                                <i class="bi bi-pencil"></i> Edit
                            </button>
                            <form asp-action="DeleteLesson" method="post" class="d-inline"
                                  onsubmit="return confirm('Delete @lesson.Title?');">
                                <input type="hidden" name="id" value="@lesson.LessonId" />
                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                    <i class="bi bi-trash3"></i> Delete
                                </button>
                            </form>
                        </td>
                    </tr>
                    index++;
                }
            }
        </tbody>
    </table>
</div>

@*ADD MODAL*@
<div class="modal fade" id="addLessonModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <form asp-action="CreateLesson" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-plus-circle"></i> Add New Lesson</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Title <span class="text-danger">*</span></label>
                        <input name="Title" class="form-control" required maxlength="200" placeholder="e.g. Lesson 1: Introduction" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Course <span class="text-danger">*</span></label>
                        <select name="CourseId" class="form-select" required>
                            <option value="">— Select Course —</option>
                            @if (courses != null)
                            {
                                foreach (var c in courses)
                                {
                                    <option value="@c.CourseId">@c.Title</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Content</label>
                        <textarea name="Content" class="form-control" rows="5" placeholder="Lesson content..."></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Slide File</label>
                        <input type="file" name="SlideFile" class="form-control" accept=".pdf,.pptx,.ppt,.docx,.doc" />
                        <div class="form-text">Accepted: PDF, PPT, DOC. Max 20MB.</div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Video File</label>
                        <input type="file" name="VideoFile" class="form-control" accept=".mp4,.webm,.mov,.avi" />
                        <div class="form-text">Accepted: MP4, WebM, MOV, AVI. Max 100MB.</div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Add Lesson</button>
                </div>
            </form>
        </div>
    </div>
</div>

@*EDIT MODAL*@
<div class="modal fade" id="editLessonModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <form asp-action="EditLesson" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <input type="hidden" name="LessonId" id="editLessonId" />
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-pencil-square"></i> Edit Lesson</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Title <span class="text-danger">*</span></label>
                        <input name="Title" id="editLessonTitle" class="form-control" required maxlength="200" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Course <span class="text-danger">*</span></label>
                        <select name="CourseId" id="editLessonCourseId" class="form-select" required>
                            <option value="">— Select Course —</option>
                            @if (courses != null)
                            {
                                foreach (var c in courses)
                                {
                                    <option value="@c.CourseId">@c.Title</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Content</label>
                        <textarea name="Content" id="editLessonContent" class="form-control" rows="5"></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Slide File</label>
                        <input type="file" name="SlideFile" class="form-control" accept=".pdf,.pptx,.ppt,.docx,.doc" />
                        <div class="form-text">Leave empty to keep current file. Max 20MB.</div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Video File</label>
                        <input type="file" name="VideoFile" class="form-control" accept=".mp4,.webm,.mov,.avi" />
                        <div class="form-text">Leave empty to keep current file. Max 100MB.</div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-warning"><i class="bi bi-check-lg"></i> Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var editModal = document.getElementById('editLessonModal');
            if (editModal) {
                editModal.addEventListener('show.bs.modal', function (event) {
                    var button = event.relatedTarget;
                    document.getElementById('editLessonId').value = button.getAttribute('data-id');
                    document.getElementById('editLessonTitle').value = button.getAttribute('data-title') || '';
                    document.getElementById('editLessonCourseId').value = button.getAttribute('data-courseid') || '';
                    document.getElementById('editLessonContent').value = button.getAttribute('data-content') || '';

                    var fileInputs = document.querySelectorAll('#editLessonModal input[type="file"]');
                    fileInputs.forEach(function(input) { input.value = ''; });
                });
            }
        });
    </script>
}
}