@{
    ViewData["Title"] = "Admin Dashboard";
    var totalUsers = ViewBag.TotalUsers ?? 0;
    var totalCourses = ViewBag.TotalCourses ?? 0;
    var totalLessons = ViewBag.TotalLessons ?? 0;
    var totalAssignments = ViewBag.TotalAssignments ?? 0;
}

@* ========== 顶部横幅 ========== *@
<div class="row mb-4">
    <div class="col-12">
        <div class="ilow-card bg-white p-4 border-start border-4 border-primary">
            <div class="d-flex flex-wrap align-items-center justify-content-between">
                <div>
                    <h1 class="h3 mb-1 fw-bold">
                        <span class="text-primary"><i class="bi bi-gear-fill me-2"></i></span>Admin Control Panel
                    </h1>
                    <p class="text-muted mb-0">Manage your entire learning platform from one place.</p>
                </div>
                <div class="text-end">
                    <div class="text-muted small fw-semibold" id="liveClock"></div>
                </div>
            </div>
        </div>
    </div>
</div>

@* ========== 四个统计卡片 ========== *@
<div class="row g-4 mb-4">
    <div class="col-md-3 col-sm-6">
        <div class="card border-0 shadow-sm text-center h-100" style="border-top: 4px solid #6366f1;">
            <div class="card-body py-4">
                <div class="display-5 fw-bold text-primary mb-1">@totalUsers</div>
                <div class="text-muted text-uppercase small fw-semibold">Users</div>
            </div>
            <a asp-action="ManageUsers" class="stretched-link"></a>
        </div>
    </div>
    <div class="col-md-3 col-sm-6">
        <div class="card border-0 shadow-sm text-center h-100" style="border-top: 4px solid #10b981;">
            <div class="card-body py-4">
                <div class="display-5 fw-bold text-success mb-1">@totalCourses</div>
                <div class="text-muted text-uppercase small fw-semibold">Courses</div>
            </div>
            <a asp-action="ManageCourses" class="stretched-link"></a>
        </div>
    </div>
    <div class="col-md-3 col-sm-6">
        <div class="card border-0 shadow-sm text-center h-100" style="border-top: 4px solid #f59e0b;">
            <div class="card-body py-4">
                <div class="display-5 fw-bold text-warning mb-1">@totalLessons</div>
                <div class="text-muted text-uppercase small fw-semibold">Lessons</div>
            </div>
            <a asp-action="ManageLessons" class="stretched-link"></a>
        </div>
    </div>
    <div class="col-md-3 col-sm-6">
        <div class="card border-0 shadow-sm text-center h-100" style="border-top: 4px solid #ef4444;">
            <div class="card-body py-4">
                <div class="display-5 fw-bold text-danger mb-1">@totalAssignments</div>
                <div class="text-muted text-uppercase small fw-semibold">Assignments</div>
            </div>
            <a asp-action="ManageAssignments" class="stretched-link"></a>
        </div>
    </div>
</div>

@* ========== 三列内容 ========== *@
<div class="row g-4">
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white border-bottom fw-semibold">
                <i class="bi bi-lightning-charge-fill text-warning me-2"></i>Quick Actions
            </div>
            <div class="card-body d-grid gap-2">
                <a asp-action="ManageCourses" class="btn btn-outline-success btn-sm text-start">
                    <i class="bi bi-plus-circle me-2"></i>New Course
                </a>
                <a asp-action="ManageLessons" class="btn btn-outline-warning btn-sm text-start">
                    <i class="bi bi-plus-circle me-2"></i>New Lesson
                </a>
                <a asp-action="ManageAssignments" class="btn btn-outline-danger btn-sm text-start">
                    <i class="bi bi-plus-circle me-2"></i>New Assignment
                </a>
                <a asp-action="ManageUsers" class="btn btn-outline-primary btn-sm text-start">
                    <i class="bi bi-people me-2"></i>View All Users
                </a>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white border-bottom fw-semibold">
                <i class="bi bi-megaphone-fill text-info me-2"></i>Announcements
            </div>
            <div class="card-body text-center text-muted py-4">
                <i class="bi bi-calendar-plus display-4 d-block mb-2"></i>
                <p>Announcements module coming soon.</p>
                <span class="badge bg-info">Planned</span>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white border-bottom fw-semibold">
                <i class="bi bi-heart-pulse-fill text-danger me-2"></i>Stress Tracker
            </div>
            <div class="card-body text-center text-muted py-4">
                <i class="bi bi-graph-up-arrow display-4 d-block mb-2"></i>
                <p>Student stress insights coming soon.</p>
                <span class="badge bg-info">Planned</span>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function updateClock() {
            var now = new Date();
            var options = {
                weekday: 'long',
                year: 'numeric',
                month: 'short',
                day: 'numeric',
                hour: '2-digit',
                minute: '2-digit',
                second: '2-digit',
                hour12: true
            };
            document.getElementById('liveClock').textContent = now.toLocaleDateString('en-GB', options);
        }
        setInterval(updateClock, 1000);
        updateClock();
    </script>
}