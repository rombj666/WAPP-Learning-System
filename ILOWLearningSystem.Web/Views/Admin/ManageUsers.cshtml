@model List<ILOWLearningSystem.Web.Models.User>
@{
    ViewData["Title"] = "Manage Users";
    var lecturers = Model.Where(u => u.Role == "Lecturer").ToList();
    var students = Model.Where(u => u.Role == "Student").ToList();
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
    <h1 class="h4 m-0">
        <i class="bi bi-people-fill text-primary me-2"></i>Manage Users
    </h1>
    <div>
        <a class="btn btn-sm btn-outline-secondary" asp-action="Dashboard">
            <i class="bi bi-arrow-left"></i> Back to Dashboard
        </a>
        <button class="btn btn-sm btn-success ms-2" data-bs-toggle="modal" data-bs-target="#addLecturerModal">
            <i class="bi bi-person-plus"></i> Add Lecturer
        </button>
    </div>
</div>

@if (TempData["Message"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Message"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@* ========== Tabs ========== *@
<ul class="nav nav-tabs mb-4" id="userTabs" role="tablist">
    <li class="nav-item" role="presentation">
        <button class="nav-link active" id="lecturer-tab" data-bs-toggle="tab" data-bs-target="#lecturer-panel" type="button" role="tab">
            <i class="bi bi-person-workspace me-1"></i>Lecturers
            <span class="badge bg-warning text-dark ms-1">@lecturers.Count</span>
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="student-tab" data-bs-toggle="tab" data-bs-target="#student-panel" type="button" role="tab">
            <i class="bi bi-people-fill me-1"></i>Students
            <span class="badge bg-primary ms-1">@students.Count</span>
        </button>
    </li>
</ul>

<div class="tab-content" id="userTabsContent">
    @* ==================== LECTURER TAB ==================== *@
    <div class="tab-pane fade show active" id="lecturer-panel" role="tabpanel">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-0">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>#</th>
                            <th>Full Name</th>
                            <th>Email</th>
                            <th>Created At</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (lecturers.Count == 0)
                        {
                            <tr><td colspan="5" class="text-center text-muted py-4">No lecturers found.</td></tr>
                        }
                        else
                        {
                            int i = 1;
                            foreach (var u in lecturers)
                            {
                                <tr>
                                    <td>@i</td>
                                    <td class="fw-semibold">@u.FullName</td>
                                    <td>@u.Email</td>
                                    <td>@u.CreatedAt.ToString("dd MMM yyyy")</td>
                                    <td class="text-end">
                                        <form asp-action="DeleteUser" method="post" class="d-inline"
                                              onsubmit="return confirm('Delete lecturer @u.FullName?');">
                                            <input type="hidden" name="id" value="@u.UserId" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                                <i class="bi bi-trash3"></i> Delete
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                                i++;
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    @* ==================== STUDENT TAB ==================== *@
    <div class="tab-pane fade" id="student-panel" role="tabpanel">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-0">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>#</th>
                            <th>Full Name</th>
                            <th>Email</th>
                            <th>Created At</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (students.Count == 0)
                        {
                            <tr><td colspan="5" class="text-center text-muted py-4">No students found.</td></tr>
                        }
                        else
                        {
                            int i = 1;
                            foreach (var u in students)
                            {
                                <tr>
                                    <td>@i</td>
                                    <td class="fw-semibold">@u.FullName</td>
                                    <td>@u.Email</td>
                                    <td>@u.CreatedAt.ToString("dd MMM yyyy")</td>
                                    <td class="text-end">
                                        <form asp-action="DeleteUser" method="post" class="d-inline"
                                              onsubmit="return confirm('Delete student @u.FullName?');">
                                            <input type="hidden" name="id" value="@u.UserId" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                                <i class="bi bi-trash3"></i> Delete
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                                i++;
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@* ==================== ADD LECTURER MODAL ==================== *@
<div class="modal fade" id="addLecturerModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="CreateLecturer" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-header bg-success text-white">
                    <h5 class="modal-title"><i class="bi bi-person-plus"></i> Create Lecturer Account</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Full Name <span class="text-danger">*</span></label>
                        <input name="FullName" class="form-control" required maxlength="200" placeholder="e.g. Dr. Sarah" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Email <span class="text-danger">*</span></label>
                        <input name="Email" type="email" class="form-control" required maxlength="320" placeholder="lecturer@ilow.local" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Password <span class="text-danger">*</span></label>
                        <input name="Password" type="password" class="form-control" required maxlength="500" placeholder="Min 6 characters" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-success"><i class="bi bi-check-lg"></i> Create Lecturer</button>
                </div>
            </form>
        </div>
    </div>
</div>