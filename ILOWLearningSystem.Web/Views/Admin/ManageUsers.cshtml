@{
    ViewData["Title"] = "Manage Users";
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
    <h1 class="h4 ilow-page-title m-0">Manage Users</h1>
    <a class="btn btn-sm btn-outline-secondary" asp-controller="Admin" asp-action="Dashboard">Back to dashboard</a>
</div>

<div class="p-4 bg-white ilow-card">
    <p class="text-muted mb-3">Placeholder list of users. Later this loads from MySQL via AppDbContext.</p>
    <div class="list-group">
        <div class="list-group-item d-flex justify-content-between align-items-center">
            <div>
                <div class="fw-semibold">Admin User</div>
                <div class="text-muted small">admin@ilow.local (Admin)</div>
            </div>
            <button class="btn btn-sm btn-outline-secondary" type="button" disabled>Edit (placeholder)</button>
        </div>
        <div class="list-group-item d-flex justify-content-between align-items-center">
            <div>
                <div class="fw-semibold">Student One</div>
                <div class="text-muted small">student1@ilow.local (Student)</div>
            </div>
            <button class="btn btn-sm btn-outline-secondary" type="button" disabled>Edit (placeholder)</button>
        </div>
    </div>
</div>
