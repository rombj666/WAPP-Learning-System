<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - I.L.O.W Learning System</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ILOWLearningSystem.Web.styles.css" asp-append-version="true" />
</head>

<body>

    <!-- NAVBAR -->
    <header class="sticky-top">
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark border-bottom">
            <div class="container-fluid">

                <a class="navbar-brand fw-semibold" asp-controller="Home" asp-action="Index">
                    I.L.O.W
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#topNav">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="topNav">

                    <!-- LEFT SIDE -->
                    <ul class="navbar-nav me-auto">

                        @if (User?.Identity?.IsAuthenticated ?? false)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Course" asp-action="Index">Courses</a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Student" asp-action="Dashboard">Student Dashboard</a>
                            </li>

                            @if (User.IsInRole(UserRoles.Admin) || User.IsInRole(UserRoles.Lecturer))
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Admin" asp-action="Dashboard">Admin</a>
                                </li>
                            }
                        }

                    </ul>

                    <!-- RIGHT SIDE -->
                    <ul class="navbar-nav ms-auto align-items-lg-center">

                        @if (User?.Identity?.IsAuthenticated ?? false)
                        {
                            <li class="nav-item me-3">
                                <a class="nav-link" asp-controller="Account" asp-action="Profile">
                                    Profile
                                </a>
                            </li>

                            <li class="nav-item me-3">
                                <span class="navbar-text text-white fw-semibold">
                                    Hello, @User.Identity!.Name
                                </span>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-danger" asp-controller="Account" asp-action="Logout">
                                    Logout
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item me-3">
                                <a class="nav-link" asp-controller="Account" asp-action="Login">
                                    Login
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Account" asp-action="Register">
                                    Register
                                </a>
                            </li>
                        }

                    </ul>

                </div>
            </div>
        </nav>
    </header>


    <!-- MAIN -->
    <div class="d-flex ilow-app">

        <!-- SIDEBAR -->
        <aside class="ilow-sidebar d-none d-lg-flex flex-column p-3 text-white">

            <div class="mb-3">
                <div class="fw-semibold">Navigation</div>
                <div class="small opacity-75">Starter skeleton</div>
            </div>

            <ul class="nav nav-pills flex-column gap-1">

                @if (User?.Identity?.IsAuthenticated ?? false)
                {
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">Home</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Course" asp-action="Index">Course List</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Lesson" asp-action="Index">Lesson List</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Assignment" asp-action="Index">Assignment List</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Student" asp-action="Dashboard">Student Dashboard</a>
                    </li>

                    @if (User.IsInRole(UserRoles.Admin) || User.IsInRole(UserRoles.Lecturer))
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Admin" asp-action="Dashboard">Admin Dashboard</a>
                        </li>
                    }
                }

            </ul>

        </aside>


        <!-- CONTENT -->
        <main class="flex-grow-1 ilow-content">
            <div class="container-fluid py-4">
                @RenderBody()
            </div>
        </main>

    </div>


    <!-- FOOTER -->
    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - I.L.O.W Learning System
        </div>
    </footer>


    <!-- SCRIPTS -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>