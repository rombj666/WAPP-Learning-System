@{
    ViewData["Title"] = "Dashboard";
}

<div class="container py-5">
    <div class="row">
        <div class="col-lg-8 mx-auto text-center">
            <i class="bi bi-mortarboard-fill display-1 text-primary mb-3"></i>
            <h1 class="display-5 fw-bold">Welcome to Your Dashboard</h1>
            <p class="lead text-muted mb-4">
                Your learning journey starts here. Browse courses, track your progress, and achieve your goals.
            </p>
            <div class="d-flex justify-content-center gap-3">
                <a asp-controller="Course" asp-action="Index" class="btn btn-primary btn-lg">
                    <i class="bi bi-book me-2"></i> Explore Courses
                </a>
                <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary btn-lg">
                    <i class="bi bi-house me-2"></i> Home
                </a>
            </div>
        </div>
    </div>
</div>