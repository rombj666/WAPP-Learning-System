@{
    ViewData["Title"] = "Home";
}

<div class="row g-4">
    <div class="col-12 col-lg-8">
        <div class="premium-card p-5">
            <h1 class="display-4 fw-bold mb-3">Welcome to I.L.O.W</h1>
            <p class="text-muted lead mb-4">
                A modern, intuitive learning platform designed to streamline your education journey.
                Access course materials, track assignments, and engage with your learning community in one place.
            </p>
            <div class="d-flex flex-wrap gap-3">
                <a class="premium-btn premium-btn-primary px-4 py-3" asp-controller="Course" asp-action="Index">
                    <i class="fa-solid fa-magnifying-glass me-2"></i> Browse Courses
                </a>
                @if (!(User.Identity?.IsAuthenticated ?? false))
                {
                    <a class="premium-btn premium-btn-outline px-4 py-3" asp-controller="Account" asp-action="Login">
                        Sign In
                    </a>
                    <a class="premium-btn premium-btn-outline px-4 py-3" asp-controller="Account" asp-action="Register">
                        Create Account
                    </a>
                }
                else
                {
                    <a class="premium-btn premium-btn-outline px-4 py-3" asp-controller="Student" asp-action="Dashboard">
                        Go to Dashboard <i class="fa-solid fa-arrow-right ms-2"></i>
                    </a>
                }
            </div>
        </div>
    </div>
    <div class="col-12 col-lg-4">
        <div class="premium-card p-4">
            <h2 class="h5 fw-bold mb-4">Quick Links</h2>
            <div class="list-group list-group-flush">
                @if (User.Identity?.IsAuthenticated ?? false)
                {
                    <a class="list-group-item list-group-item-action bg-transparent border-0 px-0 py-3 d-flex align-items-center" asp-controller="Student" asp-action="Dashboard">
                        <i class="fa-solid fa-table-columns me-3 text-primary"></i> Student Dashboard
                    </a>
                    @if (User.IsInRole("Admin") || User.IsInRole("Lecturer"))
                    {
                        <a class="list-group-item list-group-item-action bg-transparent border-0 px-0 py-3 d-flex align-items-center" asp-controller="Admin" asp-action="Dashboard">
                            <i class="fa-solid fa-user-shield me-3 text-primary"></i> Admin Dashboard
                        </a>
                    }
                    <a class="list-group-item list-group-item-action bg-transparent border-0 px-0 py-3 d-flex align-items-center" asp-controller="Course" asp-action="Index">
                        <i class="fa-solid fa-book me-3 text-primary"></i> My Courses
                    </a>
                }
                else
                {
                    <a class="list-group-item list-group-item-action bg-transparent border-0 px-0 py-3 d-flex align-items-center" asp-controller="Course" asp-action="Index">
                        <i class="fa-solid fa-book-open me-3 text-primary"></i> Explore All Courses
                    </a>
                    <a class="list-group-item list-group-item-action bg-transparent border-0 px-0 py-3 d-flex align-items-center" asp-controller="Account" asp-action="Login">
                        <i class="fa-solid fa-right-to-bracket me-3 text-primary"></i> Login to Platform
                    </a>
                }
            </div>
        </div>
    </div>
</div>
