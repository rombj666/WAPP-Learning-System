@model ILOWLearningSystem.Web.Models.StressRecord

@{
    ViewData["Title"] = "Add Stress Record";
}

<div class="container py-4">

    <div class="premium-card p-4">

        <h2 class="fw-bold mb-4">
            Record Stress Level
        </h2>

        <form asp-action="Create" method="post">

            @Html.AntiForgeryToken()

            <div class="mb-4">

                <label class="form-label fw-bold">
                    Stress Level (1 - 10)
                </label>

                <input asp-for="StressLevel"
                       class="form-control"
                       type="number"
                       min="1"
                       max="10"
                       required />

            </div>

            <div class="mb-4">

                <label class="form-label fw-bold">
                    Notes
                </label>

                <textarea asp-for="Note"
                          class="form-control"
                          rows="4"
                          placeholder="How are you feeling today?">
                </textarea>

            </div>

            <button type="submit"
                    class="btn btn-primary">
                Save Record
            </button>

            <a asp-action="Index"
               class="btn btn-secondary">
                Back
            </a>

        </form>

    </div>

</div>