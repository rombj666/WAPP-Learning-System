@model ILOWLearningSystem.Web.Models.Course
@{
    ViewData["Title"] = $"Assignments - {Model.Title}";
}

<div class="row g-4">
    <div class="col-lg-8">
        <nav aria-label="breadcrumb" class="mb-4">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-controller="Student" asp-action="Dashboard" class="text-primary text-decoration-none">Dashboard</a></li>
                <li class="breadcrumb-item"><a asp-controller="Course" asp-action="Details" asp-route-id="@Model.CourseId" class="text-primary text-decoration-none">@Model.Title</a></li>
                <li class="breadcrumb-item active">Assignments</li>
            </ol>
        </nav>

        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="h2 fw-bold mb-0">Course Assignments</h1>
            <span class="badge bg-primary rounded-pill px-3 py-2">@Model.Assignments.Count Assignments</span>
        </div>

        <div class="premium-card p-0">
            <div class="list-group list-group-flush">
                @if (Model.Assignments.Any())
                {
                    var studentSubmissions = ViewBag.Submissions as Dictionary<int, string> ?? new Dictionary<int, string>();
                    @foreach (var assignment in Model.Assignments.OrderBy(a => a.DueDate))
                    {
                        bool isOverdue = assignment.DueDate < DateTime.UtcNow;
                        studentSubmissions.TryGetValue(assignment.AssignmentId, out var status);
                        
                        <div class="list-group-item p-4 border-0 border-bottom">
                            <div class="d-flex align-items-center">
                                <div class="bg-light rounded-circle d-flex align-items-center justify-content-center me-4" style="width: 50px; height: 50px; flex-shrink: 0;">
                                    <i class="fa-solid fa-file-signature text-primary fs-5"></i>
                                </div>
                                <div class="flex-grow-1">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <div>
                                            <h5 class="fw-bold mb-1">@assignment.Title</h5>
                                            <div class="d-flex gap-3 small text-muted">
                                                <span class="@(isOverdue ? "text-danger fw-bold" : "")">
                                                    <i class="fa-regular fa-calendar-xmark me-1"></i>
                                                    Due: @(assignment.DueDate?.ToString("MMM dd, yyyy") ?? "No deadline")
                                                </span>
                                                <span>
                                                    <i class="fa-solid fa-star me-1"></i>
                                                    @assignment.TotalMarks Marks
                                                </span>
                                                @if (status != null)
                                                {
                                                    <span class="status-badge status-@status.Replace(" ", "-").ToLower() py-0 px-2" style="font-size: 0.7rem;">
                                                        @status
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="status-badge status-pending py-0 px-2" style="font-size: 0.7rem;">
                                                        Pending
                                                    </span>
                                                }
                                            </div>
                                        </div>
                                        <a asp-action="Details" asp-route-id="@assignment.AssignmentId" class="premium-btn premium-btn-primary btn-sm px-4">
                                            View & Submit
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="p-5 text-center">
                        <i class="fa-solid fa-tasks text-muted mb-3" style="font-size: 3rem;"></i>
                        <h4 class="text-muted">No assignments yet</h4>
                        <p class="text-muted mb-0">Check back later for course assignments.</p>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="premium-card p-4 mb-4">
            <h3 class="h5 fw-bold mb-4">Navigation</h3>
            <div class="nav-btn-list">
                <a asp-controller="Course" asp-action="Details" asp-route-id="@Model.CourseId" class="nav-btn-item">
                    <i class="fa-solid fa-circle-info"></i> Course Overview
                </a>
                <a asp-controller="Lesson" asp-action="ByCourse" asp-route-courseId="@Model.CourseId" class="nav-btn-item">
                    <i class="fa-solid fa-play"></i> View Lessons
                </a>
                <a asp-controller="Student" asp-action="Dashboard" class="nav-btn-item">
                    <i class="fa-solid fa-table-columns"></i> Back to Dashboard
                </a>
                @if (User.IsInRole("Admin") || User.IsInRole("Lecturer"))
                {
                    <a asp-action="Create" asp-route-courseId="@Model.CourseId" class="nav-btn-item text-primary">
                        <i class="fa-solid fa-plus"></i> Create Assignment
                    </a>
                }
            </div>
        </div>
    </div>
</div>
