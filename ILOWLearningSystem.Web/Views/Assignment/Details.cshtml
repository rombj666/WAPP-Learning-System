@model ILOWLearningSystem.Web.Models.Assignment
@{
    ViewData["Title"] = Model.Title;
    var submission = ViewBag.Submission as ILOWLearningSystem.Web.Models.Submission;
    var submitModel = new ILOWLearningSystem.Web.Models.SubmitAssignmentViewModel { AssignmentId = Model.AssignmentId };
}

<div class="row justify-content-center">
    <div class="col-lg-10 col-xl-8">
        <nav aria-label="breadcrumb" class="mb-4">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-controller="Student" asp-action="Dashboard" class="text-primary text-decoration-none">Dashboard</a></li>
                <li class="breadcrumb-item"><a asp-controller="Course" asp-action="Details" asp-route-id="@Model.CourseId" class="text-primary text-decoration-none">@Model.Course?.Title</a></li>
                <li class="breadcrumb-item active">Assignment</li>
            </ol>
        </nav>

        <!-- Assignment Info Section -->
        <div class="mb-5">
            <div class="d-flex justify-content-between align-items-start mb-2">
                <h1 class="display-5 fw-bold mb-0">@Model.Title</h1>
                <div class="text-end">
                    <div class="h5 fw-bold text-primary mb-0">@Model.TotalMarks Marks</div>
                    <small class="text-muted">Max Score</small>
                </div>
            </div>
            <div class="d-flex align-items-center gap-3">
                <span class="text-muted"><i class="fa-solid fa-book me-2"></i>@Model.Course?.Title</span>
                @if (Model.DueDate.HasValue)
                {
                    <span class="@(Model.DueDate < DateTime.UtcNow ? "text-danger" : "text-muted") fw-bold">
                        <i class="fa-solid fa-calendar-clock me-2"></i>Due: @Model.DueDate?.ToString("MMM dd, yyyy")
                    </span>
                }
            </div>
        </div>

        <!-- Instructions Card -->
        <div class="premium-card p-4 p-md-5 mb-4">
            <h3 class="h4 fw-bold mb-4">Instructions</h3>
            <div class="instructions-content text-muted mb-0">
                @if (!string.IsNullOrEmpty(Model.Description))
                {
                    @Model.Description
                }
                else
                {
                    <p class="mb-0">No specific instructions provided for this assignment.</p>
                }
            </div>
        </div>

        <!-- Submission Section -->
        <div class="premium-card p-4 p-md-5 mb-5 border-top border-4 border-primary">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h3 class="h4 fw-bold mb-0">My Submission</h3>
                @if (submission != null)
                {
                    <span class="status-badge status-@submission.Status.Replace(" ", "-").ToLower()">
                        @submission.Status
                    </span>
                }
                else
                {
                    <span class="status-badge status-pending">Not Submitted</span>
                }
            </div>

            @if (submission?.Status == "Graded")
            {
                <div class="bg-light p-4 rounded-3 mb-4">
                    <div class="row align-items-center">
                        <div class="col-md-8">
                            <h5 class="fw-bold mb-2">Feedback from Lecturer</h5>
                            <p class="mb-0 text-muted">@submission.Feedback</p>
                        </div>
                        <div class="col-md-4 text-md-end mt-3 mt-md-0">
                            <div class="display-6 fw-bold text-success">@submission.Score / @Model.TotalMarks</div>
                        </div>
                    </div>
                </div>
            }

            <form asp-controller="Submission" asp-action="Submit" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <input type="hidden" name="AssignmentId" value="@Model.AssignmentId" />
                
                <div class="mb-4">
                    <label class="form-label fw-bold">Submission Notes (Optional)</label>
                    <textarea name="Notes" class="form-control form-control-premium" rows="4" placeholder="Enter any notes or your text submission here...">@submission?.SubmissionText</textarea>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-bold">Upload File (Optional)</label>
                    <div class="p-4 border border-2 border-dashed rounded-3 text-center bg-light">
                        <i class="fa-solid fa-cloud-arrow-up fs-2 text-primary mb-3"></i>
                        <input type="file" name="File" class="form-control" />
                        <div class="mt-2 small text-muted">Max file size: 10MB (PDF, ZIP, DOCX preferred)</div>
                    </div>
                    @if (!string.IsNullOrEmpty(submission?.FilePath))
                    {
                        <div class="mt-3 p-3 bg-white rounded-3 border d-flex align-items-center">
                            <i class="fa-solid fa-file-circle-check text-success me-3 fs-4"></i>
                            <div class="flex-grow-1">
                                <div class="fw-bold small">Current File:</div>
                                <a href="/@submission.FilePath" target="_blank" class="text-primary small text-decoration-none">View Submission</a>
                            </div>
                            <small class="text-muted">Last updated: @submission.SubmittedAt.ToString("MMM dd, HH:mm")</small>
                        </div>
                    }
                </div>

                <div class="d-grid">
                    <button type="submit" class="premium-btn premium-btn-primary py-3">
                        @(submission == null ? "Submit Assignment" : "Update Submission")
                    </button>
                </div>
            </form>
        </div>

        <div class="d-flex justify-content-between align-items-center mb-5">
            <a asp-controller="Course" asp-action="Details" asp-route-id="@Model.CourseId" class="premium-btn premium-btn-outline">
                <i class="fa-solid fa-arrow-left me-2"></i> Back to Course
            </a>
            <a asp-controller="Submission" asp-action="MyStatus" class="premium-btn premium-btn-outline">
                View All Submissions
            </a>
        </div>
    </div>
</div>

<style>
    .instructions-content {
        line-height: 1.8;
        font-size: 1.1rem;
    }
    .border-dashed {
        border-style: dashed !important;
    }
</style>
