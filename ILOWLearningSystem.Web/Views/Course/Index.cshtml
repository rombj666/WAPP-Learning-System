@{
    ViewData["Title"] = "Course List";
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
    <h1 class="h4 ilow-page-title m-0">Course List</h1>
    <div class="d-flex gap-2">
        <a class="btn btn-sm btn-outline-secondary" asp-controller="Admin" asp-action="ManageCourses">Manage Courses</a>
        <a class="btn btn-sm btn-primary" asp-controller="Course" asp-action="Create">Create Course</a>
    </div>
</div>

<div class="p-4 bg-white ilow-card">
    <p class="text-muted mb-3">Placeholder list. Later this loads from MySQL via AppDbContext.</p>
    <div class="list-group">
        <a class="list-group-item list-group-item-action" asp-controller="Course" asp-action="Details" asp-route-id="1">
            Course #1 - Introduction to ILOW
        </a>
        <a class="list-group-item list-group-item-action" asp-controller="Course" asp-action="Details" asp-route-id="2">
            Course #2 - Placeholder
        </a>
    </div>
</div>
