@{
    ViewData["Title"] = "Lesson Details";
    var lessonId = (int)(ViewData["LessonId"] ?? 0);
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
    <h1 class="h4 ilow-page-title m-0">Lesson Details</h1>
    <a class="btn btn-sm btn-outline-secondary" asp-controller="Lesson" asp-action="Index">Back to list</a>
</div>

<div class="p-4 bg-white ilow-card">
    <div class="text-muted small mb-2">LessonId: @lessonId</div>
    <div class="fw-semibold mb-2">Title (placeholder)</div>
    <p class="text-muted mb-3">Lesson content, slides, video, and flashcards will appear here.</p>

    <div class="d-flex flex-wrap gap-2">
        <a class="btn btn-sm btn-outline-primary" asp-controller="Course" asp-action="Details" asp-route-id="1">Back to Course</a>
        <button class="btn btn-sm btn-outline-secondary" type="button" disabled>Generate Flashcards (placeholder)</button>
    </div>
</div>
